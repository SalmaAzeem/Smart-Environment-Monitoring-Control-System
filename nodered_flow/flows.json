    {
        "id": "fd708b504f0ca1d3",
        "type": "function",
        "z": "39ebbb46faa894a5",
        "name": "function 13",
        "func": "let alertText = \"\";\n\nif (msg.topic === \"salma/sensors/temperature\") {\n    let temp = msg.payload.value !== undefined ? msg.payload.value : Number(msg.payload);\n   \n    if (temp > 35) {\n        alertText = \"HIGH TEMPERATURE: \" + temp + \"C\";\n    }\n}\nelse if (msg.topic === \"salma/sensors/motion\") {\n    let motion = msg.payload.detected !== undefined ? msg.payload.detected : msg.payload;\n   \n    if (motion === true || motion === \"true\" || motion == 1) {\n        alertText = \"MOTION DETECTED\";\n    }\n}\n\nif (alertText !== \"\") {\n    msg.payload = alertText;\n    msg.timestamp = new Date().toLocaleString();\n    return msg;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
