        "type": "function",
        "z": "39ebbb46faa894a5",
        "name": "function 16",
        "func": "let temp = flow.get(\"temp_max\") || 50;\nlet light = flow.get(\"light_min\") || 1000;\nlet dist = flow.get(\"dist_min\") || 200;\n\nif (msg.topic === \"temp_max\") {\n    temp = msg.payload;\n    flow.set(\"temp_max\", temp);\n} else if (msg.topic === \"light_min\") {\n    light = msg.payload;\n    flow.set(\"light_min\", light);\n} else if (msg.topic === \"dist_min\") {\n    dist = msg.payload;\n    flow.set(\"dist_min\", dist);\n}\n\nmsg.payload = {\n    \"temp_max\": temp,\n    \"light_min\": light,\n    \"dist_min\": dist\n};\n\nreturn msg;",
        "outputs": 1,
